# =============================================
# LIFEHUB - Variables de entorno
# =============================================
# Copia este archivo a .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.

# ── Base de datos ────────────────────────────────────────────────────────────
# Contraseña del usuario SA de SQL Server
# Requisitos: mínimo 8 caracteres, mayúsculas, minúsculas, números y símbolo
DB_PASSWORD=change_me_strong_password_Abc123!

# Nombre de la base de datos
DB_NAME=LifeHubDB

# Usuario de SQL Server
DB_USER=sa

# Host de SQL Server (dentro del contenedor suele ser localhost)
DB_HOST=localhost

# ── Contenedores Docker ──────────────────────────────────────────────────────
# Nombre del contenedor de SQL Server
SQL_CONTAINER=lifehub-sql-dev

# Nombre del contenedor del backend (usado en restore para reinicio)
BACKEND_CONTAINER=lifehub-backend-dev

# Ruta completa al ejecutable sqlcmd dentro del contenedor SQL
# dev  (azure-sql-edge): /opt/mssql-tools/bin/sqlcmd
# prod (mssql/server):   /opt/mssql-tools18/bin/sqlcmd
SQLCMD_PATH=/opt/mssql-tools/bin/sqlcmd

# ── Autenticación ────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT
# Requisitos: mínimo 32 caracteres, preferiblemente aleatoria
JWT_KEY=change_me_jwt_secret_key_minimum_32_characters_long_random

# ── Credenciales de pruebas ──────────────────────────────────────────────────
# Credenciales del usuario administrador (usadas por run-tests.ps1)
ADMIN_EMAIL=change_me_admin_email
ADMIN_PASSWORD=change_me_admin_password
