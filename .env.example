# =============================================
# LIFEHUB - Variables de entorno
# =============================================
# Copia este archivo a .env.dev y rellena los valores de desarrollo.
# En producción copia a .env.prod con los valores del servidor.
# NUNCA subas .env.dev ni .env.prod al repositorio.

# ── Base de datos ────────────────────────────────────────────────────────────
# Contraseña del usuario SA — mínimo 8 chars, mayús, minús, número y símbolo
DB_PASSWORD=

# Nombre de la base de datos
DB_NAME=LifeHubDB

# Usuario de SQL Server
DB_USER=sa

# Host de SQL Server usado por el backend dentro de la red Docker
# prod: sqlserver
DB_HOST=sqlserver

# Edición/licencia de SQL Server para el contenedor
# Opciones comunes: Express, Developer
MSSQL_PID=Express

# ── Contenedores Docker ──────────────────────────────────────────────────────
# Nombre del contenedor de SQL Server
# dev:  lifehub-sql-dev
# prod: lifehub-sqlserver
SQL_CONTAINER=lifehub-sqlserver

# Nombre del contenedor del backend (usado en restore para recordar el reinicio)
# dev:  lifehub-backend-dev
# prod: lifehub-backend
BACKEND_CONTAINER=lifehub-backend

# Nombre del contenedor del frontend
# dev:  lifehub-frontend-dev
# prod: lifehub-frontend
FRONTEND_CONTAINER=lifehub-frontend

# Puerto interno del backend en el contenedor
BACKEND_PORT=8080

# Puerto público del frontend en el servidor
PUBLIC_PORT=80

# Entorno de ASP.NET Core
# dev: Development
# prod: Production
ASPNETCORE_ENVIRONMENT=Production

# Ruta al ejecutable sqlcmd dentro del contenedor SQL
# dev  (azure-sql-edge): /opt/mssql-tools/bin/sqlcmd
# prod (mssql/server):   /opt/mssql-tools18/bin/sqlcmd
SQLCMD_PATH=/opt/mssql-tools/bin/sqlcmd

# Opciones extra para sqlcmd (separadas por espacios)
# dev:  dejar vacío
# prod: -C  (acepta el certificado autofirmado del contenedor)
SQLCMD_OPTS=

# ── Autenticación ────────────────────────────────────────────────────────────
# Clave secreta para firmar los tokens JWT — mínimo 32 caracteres, aleatoria
JWT_KEY=

# ── Servidor de producción (solo necesario para restore-prod-db.ps1) ─────────
# Host SSH del servidor donde corre Docker en producción
PROD_SERVER_HOST=

# Usuario SSH con permisos para ejecutar docker en el servidor
PROD_SERVER_USER=

# ── Credenciales de pruebas ──────────────────────────────────────────────────
# Usuario administrador usado por los scripts de test
ADMIN_EMAIL=
ADMIN_PASSWORD=
